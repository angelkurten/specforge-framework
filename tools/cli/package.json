{
  "name": "@angelkurten/specforge",
  "version": "0.7.0",
  "description": "CLI for installing, updating, validating, and migrating specforge framework layouts.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/angelkurten/specforge-framework.git",
    "directory": "tools/cli"
  },
  "type": "module",
  "bin": {
    "specforge": "./dist/src/cli.js"
  },
  "files": [
    "dist/",
    "framework/",
    "migrations/",
    "README.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.scripts.json",
    "prepublish": "node dist-scripts/scripts/prepublish.js",
    "prepublishOnly": "npm run build && npm run prepublish",
    "test": "vitest run"
  },
  "dependencies": {
    "diff3": "0.0.4",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
